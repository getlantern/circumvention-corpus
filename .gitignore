# Local PDFs are not committed — they're a cache, not a source of truth.
# The canonical URL lives in the YAML. Each user can populate this dir
# locally if they want.
corpus/pdfs/
# Extracted plain-text — derived from pdfs/, used by full-text findings
# extraction. Regenerable; not committed.
corpus/text/

# Go build artifacts. The launchd wrapper (deploy/run-crawl.sh) builds
# corpus-crawl + corpus-findings in-tree on each fire — they're
# transient and reproducible from source.
/corpus-mcp
/corpus-crawl
/corpus-findings
/corpus-bundle
/corpus-site
/import-censorbib
/retag-papers
/dist/
*.test
*.out

# Wrangler local state.
/.wrangler/

# Worker artifacts. functions/_data/corpus.json is regenerated by
# cmd/corpus-bundle/ on every deploy; node_modules is for local
# typecheck only.
/functions/_data/
/node_modules/

# Editors / OS noise.
.vscode/
.idea/
.DS_Store

# Service-account JSONs etc., in case anyone runs the (future) crawlers
# locally and forgets to put creds elsewhere.
*service-account*.json
*.key
.env
.env.*
